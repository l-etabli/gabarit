{
  "name": "@#{npm_scope}#/#{project_name}#",
  "description": "#{project_description}#",
  "module": "./dist/index.js",
  "type": "module",
  "version": "0.0.0-development",
  "packageManager": "bun@1.3.14",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/#{npm_scope}#/#{project_name}#.git"
  },
  "homepage": "https://github.com/#{npm_scope}#/#{project_name}##readme",
  "bugs": {
    "url": "https://github.com/#{npm_scope}#/#{project_name}#/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "check": "biome check",
    "check:fix": "biome check --fix --no-errors-on-unmatched --files-ignore-unknown=true",
    "test": "bun test",
    "test:package": "node scripts/package-smoke.mjs && tsc --ignoreConfig --noEmit --module NodeNext --moduleResolution NodeNext --target ESNext dist/index.d.ts",
    "typecheck": "tsc --noEmit",
    "fullcheck": "bun run check && bun run typecheck && bun run test",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "semantic-release": "^25.0.8",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
